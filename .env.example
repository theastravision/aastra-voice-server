# Copy to .env — OSS STT/TTS + OpenAI chat only
VOICE_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_COMPLETION_TOKENS=64
OPENAI_VOICE_TEMPERATURE=0.5
CHAT_HISTORY_MAX_TURNS=8

# Technical AI interviewer
BOT_MODE=interview
INTERVIEW_STRICT_MODE=true
INTERVIEW_OPENING_ENABLED=true
INTERVIEW_JOB_TITLE=Software Engineer
DEMO_CANDIDATE_NAME=Aashish

# TTS — F5-TTS + Vocos (bash scripts/install-f5-tts.sh)
TTS_PROVIDER=f5
F5_MODEL=F5TTS_v1_Base
F5_NFE_STEPS=12
F5_SWAY_COEF=-1.0
# Speech pace: 0.75–0.90 = slower/clearer; 1.0 = default F5 speed
F5_SPEED=1.0
F5_CROSS_FADE_DURATION=0.15
F5_NO_SPLIT_MAX_CHARS=120
F5_DEVANAGARI_NO_SPLIT_MAX_CHARS=90
F5_CFG_STRENGTH=2.2
F5_HINGLISH_SCRIPT=devanagari
F5_REF_AUDIO_EN=assets/voices/astra_ref.wav
F5_REF_TEXT_EN=Hello! My name is Astra. Please keep sharing your screen; you may check it. Whenever you are ready, we can begin the interview.
F5_REF_AUDIO_HINGLISH=assets/voices/astra_ref_hinglish.wav
F5_REF_TEXT_HINGLISH=नमस्ते, मैं Astra हूँ। शुरू करने से पहले, screen share on रखें। मैं आज आपका technical interview लूँगी। कृपया अपना naam बताइए।
# Must match spoken content in astra_ref_hinglish.wav — regenerate after change:
#   python scripts/setup_ref_audio.py --force --voice-id astra_hinglish
# edge-tts voice for scripts/setup_ref_audio.py only (Sapna = kn-IN Kannada neural)
ASTRA_EDGE_TTS_VOICE=kn-IN-SapnaNeural
F5_DTYPE=float16
F5_VOCODER=vocos

# Hinglish TTS: Devanagari preprocessing + optional XTTS fallback
TTS_OUTPUT_SCRIPT=devanagari
TTS_DEVANAGARI_SOURCE=llm
TTS_LLM_SCRIPT_STRICT=true
TTS_HINGLISH_ENGINE=f5_devanagari
TTS_HINGLISH_ROMAN=true
TTS_HINGLISH_PACE_PAUSES=true
# Phonetic syllable breaks (hyphen/space) — disabled; use pacing + F5_HINGLISH_SPEED instead
# TTS_HINGLISH_PHONETIC_HYPHEN=false
# STT_HINGLISH_PHONETIC_DENORM=false
TTS_HINGLISH_PAUSE_STYLE=story
F5_HINGLISH_SPEED=0.82
# English → F5. Indic (hi/hinglish + 19 langs) → embedded svara-TTS
TTS_INDIC_ENGINE=svara
SVARA_MODEL=kenpath/svara-tts-v1
SVARA_VLLM_GPU_MEMORY_UTILIZATION=0.50
SVARA_SNAC_DEVICE=cuda
SVARA_DEFAULT_VOICE=Hindi (Female)
SVARA_HINGLISH_VOICE=Hindi (Female)
# SVARA_EMOTION_TAG=<clear>
# Install: bash scripts/install-svara-tts.sh
MELOTTS_SPEAKER=EN-IND
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_SPEAKER_WAV=assets/voices/astra_ref.wav
XTTS_DEVICE=cuda
XTTS_LANGUAGE=hi

STREAM_LLM_MIN_WORDS=5
STREAM_LLM_NEXT_MIN_WORDS=5
INTERJECTION_TIMEOUT_MS=300
STREAM_LISTEN_IDLE_SECS=8
# Max silence (seconds) before stopping idle nudges while waiting for an answer
STREAM_LISTEN_IDLE_MAX_SECS=60
STREAM_STT_MIN_CHARS=4
STT_PROVIDER=whisper
STT_UTTERANCE_MAX_SECS=90
STT_TRANSCRIBE_TIMEOUT_SECS=120
TTS_OUTPUT_FORMAT=wav

WHISPER_MODEL=distil-large-v3
# Faster alternatives: base (~fastest, weaker Hindi) | large-v3 (~best quality, slowest)
STT_SILERO_TRIGGER_END_UTTERANCE=false
WHISPER_LANGUAGE=auto
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=1
STT_VAD_SILENCE_MS=500
STT_MIN_SPEECH_MS=300
STT_SILENCE_END_MS=900
STREAM_SILENCE_END_MS=900
SILERO_VAD_THRESHOLD=0.5
# Whisper VAD secondary filter — Silero VAD handles primary gating; auto-off for whisper/silero_whisper STT
WHISPER_VAD_FILTER=true
# WHISPER_VAD_FORCE=true  # force ONNX VAD even when SileroWhisperSTT is active
# ORT_LOGGING_LEVEL=3     # suppress ONNX Runtime DRM warnings (default applied in core/ort_env.py)
WHISPER_INITIAL_PROMPT="Hinglish conversation mixing Hindi and English. हिंदी और अंग्रेज़ी मिश्रित बातचीत।"

STREAM_ALLOW_PUBLIC=true
STREAM_SAMPLE_RATE=16000
STREAM_CHUNK_MS=30
STREAM_STT_WINDOW_MS=600

HOST=*
PORT=8000
ALLOW_PUBLIC_DEMO=true

# ngrok public tunnel (optional — used by scripts/run-all.sh)
NGROK_AUTHTOKEN=

# ── Redis Streams pub/sub (lightweight Kafka alternative) ─────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MAX_STREAM_LEN=1000
REDIS_STREAM_TTL_SECS=3600

VOICES_REGISTRY_PATH=data/voices.json
STT_MODELS_REGISTRY_PATH=data/models.json
TRAINING_DATA_ROOT=data/training
TRAINING_CHECKPOINTS_ROOT=data/checkpoints

# Hinglish vocab CSVs (data/vocab/hinglish_words.csv, hinglish_conversations.csv)
HINGLISH_VOCAB_DIR=data/vocab
HINGLISH_SYNTH_MAX_ROWS=5000
HINGLISH_SYNTH_VOICE_ID=astra
TRAINING_CHECKPOINTS_ROOT=data/checkpoints
WHISPER_FINETUNE_BASE=openai/whisper-base
WHISPER_FINETUNE_EPOCHS=3
