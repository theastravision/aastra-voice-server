# Demo/Salad Environment Configuration

VOICE_API_KEY=
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_COMPLETION_TOKENS=64
OPENAI_VOICE_TEMPERATURE=0.5
CHAT_HISTORY_MAX_TURNS=8

# Technical AI interviewer
BOT_MODE=interview
INTERVIEW_STRICT_MODE=true
INTERVIEW_OPENING_ENABLED=true
INTERVIEW_JOB_TITLE=Software Engineer
DEMO_CANDIDATE_NAME=Aashish

# TTS — F5-TTS + Vocos (English)
TTS_PROVIDER=f5
F5_MODEL=F5TTS_v1_Base
F5_NFE_STEPS=18
F5_SWAY_COEF=-1.0
F5_SPEED=1.0
F5_CROSS_FADE_DURATION=0.15
F5_NO_SPLIT_MAX_CHARS=120
F5_DEVANAGARI_NO_SPLIT_MAX_CHARS=90
F5_CFG_STRENGTH=2.2
F5_HINGLISH_SCRIPT=devanagari
F5_REF_AUDIO=assets/voices/astra_ref_hinglish.wav
F5_REF_TEXT=Namaste, main Astra hoon. Shuru karne se pehle, screen share on rakhein. I will conduct your technical interview today. Kripya apna naam batayiye.
ASTRA_EDGE_TTS_VOICE=en-IN-NeerjaNeural
F5_DTYPE=float16
F5_VOCODER=vocos

# Hinglish TTS: MeloTTS Integration
TTS_OUTPUT_SCRIPT=devanagari
TTS_DEVANAGARI_SOURCE=llm
TTS_LLM_SCRIPT_STRICT=true
TTS_HINGLISH_ENGINE=melotts

MELOTTS_DEVICE=cuda
MELOTTS_SPEED=1.0
MELOTTS_SPEAKER=EN-BR

# Streaming and Barge-in (Low Latency Tuning)
STREAM_LLM_MIN_WORDS=3
STREAM_LLM_NEXT_MIN_WORDS=3
INTERJECTION_TIMEOUT_MS=300
STREAM_LISTEN_IDLE_SECS=3
STREAM_STT_MIN_CHARS=8
STT_UTTERANCE_MAX_SECS=90
STT_TRANSCRIBE_TIMEOUT_SECS=120
TTS_OUTPUT_FORMAT=wav
BARGE_IN_THRESHOLD=0.03

# Whisper STT
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=1
STT_VAD_SILENCE_MS=300
STT_MIN_SPEECH_MS=200
WHISPER_VAD_FILTER=false
WHISPER_INITIAL_PROMPT="Hinglish conversation mixing Hindi and English. हिंदी और अंग्रेज़ी मिश्रित बातचीत।"

STREAM_ALLOW_PUBLIC=true
STREAM_SAMPLE_RATE=16000
STREAM_CHUNK_MS=20
STREAM_STT_WINDOW_MS=400

HOST=0.0.0.0
PORT=8000
ALLOW_PUBLIC_DEMO=true

# ngrok public tunnel (optional)
NGROK_AUTHTOKEN=

# ── Redis Streams pub/sub ─────────────────────
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MAX_STREAM_LEN=1000
REDIS_STREAM_TTL_SECS=3600

# Registry & Training Paths
VOICES_REGISTRY_PATH=data/voices.json
STT_MODELS_REGISTRY_PATH=data/models.json
TRAINING_DATA_ROOT=data/training
TRAINING_CHECKPOINTS_ROOT=data/checkpoints

HINGLISH_VOCAB_DIR=data/vocab
HINGLISH_SYNTH_MAX_ROWS=5000
HINGLISH_SYNTH_VOICE_ID=astra
WHISPER_FINETUNE_BASE=openai/whisper-base
WHISPER_FINETUNE_EPOCHS=3
