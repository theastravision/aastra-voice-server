      template <typename T>
      struct LoadImpl {
        __device__ static T apply(const void *src) {
          return *reinterpret_cast<const T*>(src);
        }
      };
  
      template <>
      struct LoadImpl<bool> {
        __device__ static bool apply(const void *src) {
