import React, { useState, useEffect, useRef } from 'react';

export default function AstraInterviewDashboard() {
  const [sessionStarted, setSessionStarted] = useState(false);
  const [selectedLanguage, setSelectedLanguage] = useState('en'); // Defaults to English
  const [interviewState, setInterviewState] = useState('STARTING...');
  const [humanText, setHumanText] = useState('');
  const [astraText, setAstraText] = useState('');
  
  const ws = useRef(null);

  const startInterviewSession = () => {
    setSessionStarted(true);
    
    // Connect to backend orchestration pool
    ws.current = new WebSocket("ws://localhost:8000/ws/interview");

    ws.current.onopen = () => {
      // Send standard language lock config directly down the pipeline
      const configurationPayload = {
        type: "setup_session",
        language: selectedLanguage
      };
      ws.current.send(JSON.stringify(configurationPayload));
      setInterviewState('LISTENING');
    };

    ws.current.onmessage = async (event) => {
      if (typeof event.data === "string") {
        const response = JSON.parse(event.data);
        if (response.type === "human_transcript") {
          setHumanText(response.text);
        } else if (response.type === "astra_transcript") {
          setAstraText(response.text);
        }
      } else {
        // Handle explicit incoming voice playback stream layers
        const audioBlob = new Blob([event.data], { type: 'audio/wav' });
        const audioUrl = URL.createObjectURL(audioBlob);
        const audio = new Audio(audioUrl);
        
        // Broadcast playback state so backend drops incoming microphone feed data (Echo Cancellation)
        ws.current.send(JSON.stringify({ type: "astra_playback_state", speaking: true }));
        setInterviewState('ASTRA SPEAKING');
        
        await audio.play();
        
        audio.onended = () => {
          ws.current.send(JSON.stringify({ type: "astra_playback_state", speaking: false }));
          setInterviewState('LISTENING');
        };
      }
    };
  };

  return (
    <div className="min-h-screen bg-[#0b0f19] flex items-center justify-center text-white font-sans p-6">
      {!sessionStarted ? (
        /* Dynamic Pre-Selection Interface Card Block Layout */
        <div className="w-full max-w-md bg-[#131a2e] rounded-2xl border border-slate-800 p-8 text-center shadow-2xl">
          <h2 className="text-2xl font-bold text-slate-100 mb-2">Astra Voice Engine Setup</h2>
          <p className="text-sm text-slate-400 mb-6">Select your primary communication language prior to initializing the engine.</p>
          
          <div className="mb-8 text-left">
            <label className="block text-xs font-semibold text-indigo-400 uppercase tracking-wider mb-2">Interview Language</label>
            <select 
              value={selectedLanguage} 
              onChange={(e) => setSelectedLanguage(e.target.value)}
              className="w-full bg-[#1c2642] text-white border border-slate-700 rounded-xl px-4 py-3 outline-none focus:border-indigo-500 transition-all cursor-pointer font-medium"
            >
              <option value="en">English (Technical Indian Profile - Female/Mary)</option>
              <option value="hi">Hindi (हिंदी - Female/Divya)</option>
            </select>
          </div>

          <button 
            onClick={startInterviewSession}
            className="w-full bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-semibold py-3 px-6 rounded-xl shadow-lg transform hover:-translate-y-0.5 active:translate-y-0 transition-all duration-150"
          >
            Launch Interview Session
          </button>
        </div>
      ) : (
        /* Real-Time Live Status Panel View Component */
        <div className="w-full max-w-lg bg-[#131a2e] rounded-3xl border border-slate-800 p-8 flex flex-col items-center text-center shadow-2xl relative">
          <div className="text-sm tracking-widest text-indigo-400 font-semibold uppercase mb-1">Astra</div>
          <div className="text-xs text-slate-400 font-medium mb-8">Technical Interview • Software Engineer</div>
          
          {/* Animated Waveform/Voice Status Indicator Circle Ring */}
          <div className={`w-32 h-32 rounded-full flex items-center justify-center mb-6 border-4 shadow-xl transition-all duration-300 ${
            interviewState === 'ASTRA SPEAKING' ? 'border-purple-500 bg-purple-950/30 animate-pulse' : 'border-indigo-500 bg-indigo-950/30'
          }`}>
            <svg className="w-12 h-12 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>

          <div className="text-indigo-400 font-mono tracking-widest text-sm mb-8 animate-pulse font-bold">{interviewState}</div>

          {/* Subtitle Dialogue Transcript Area Blocks */}
          <div className="w-full bg-[#0b0f19]/80 rounded-2xl p-4 text-left border border-slate-800 space-y-3 min-h-[120px] max-h-[200px] overflow-y-auto mb-6">
            {humanText && (
              <p className="text-xs text-slate-300"><strong className="text-indigo-400">You:</strong> {humanText}</p>
            )}
            {astraText && (
              <p className="text-xs text-slate-300"><strong className="text-purple-400">Astra:</strong> {astraText}</p>
            )}
          </div>

          <button 
            onClick={() => window.location.reload()}
            className="w-full bg-rose-950/40 border border-rose-800/60 text-rose-400 font-medium py-2.5 rounded-xl text-sm transition-colors hover:bg-rose-900/40"
          >
            End Interview
          </button>
        </div>
      )}
    </div>
  );
}